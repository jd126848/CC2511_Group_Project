BoxLayout:
    orientation: "vertical"

    BoxLayout:
        size_hint_y: 0.9
        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.3
            Button:
                text: "Calibrate"
            BoxLayout:
                Label:
                    text: "Spindle Speed"
                Spinner:
                    id: spindle_speed_spinner
                    text_autoupdate: True
                    values: ["Off", "Low", "Medium", "Fast", "Very Fast"]
                    on_text: app.set_spindle_speed()
            BoxLayout:
                Label:
                    text: "Microstepping"
                Spinner:
                    id: microsteps_spinner
                    text_autoupdate: True
                    values: ["1step/step", "2microsteps/step", "4microsteps/step", "8microsteps/step", "16microsteps/step", "32microsteps/step"]
                    on_text: app.set_microsteps()
            Button:
                background_color: "red"
                text: "Import G-Code File"
                on_release: app.handle_gcode()
        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.7
            BoxLayout:
                orientation: "vertical"
                size_hint_y: 0.2
                Label:
                    size_hint_y: 0.8
                    text: "Use WASD to control the horizontal position, E to raise the drill, Q to lower it\nBefore use, calibrate the drills position to prevent grating at limits\nImport G-Code files for predefined movements"
                Label:
                    size_hint_y: 0.2
                    text: app.coords_text
            BoxLayout:
                canvas:
                    Color:
                        rgba: 1,1,1,1
                    Rectangle:
                        pos: self.x, self.y + (self.height - self.width * 175/300) / 2
                        size: self.width, self.width*175/300
                    Color:
                        rgba: 1, 0, 0, 1
                    Ellipse:
                        size: 15,15
                        pos: 100, 100


    BoxLayout:
        size_hint_y: 0.07
        canvas:
            Color:
                rgba: 0.1, 0.1, 0.1, 1
            Rectangle:
                pos: self.pos
                size: self.size
        Label:
            text: app.status_text

